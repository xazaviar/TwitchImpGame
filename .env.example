# Server
PORT=3001
NODE_ENV=development

# Twitch OAuth (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3001/api/auth/twitch/callback

# Twitch Bot
TWITCH_BOT_USERNAME=
TWITCH_BOT_OAUTH_TOKEN=
TWITCH_CHANNEL=

# Streamer's Twitch ID (for admin access)
STREAMER_TWITCH_ID=

# JWT Secret (generate a random string)
JWT_SECRET=change-me-to-a-random-secret

# Admin API Key (for Stream Deck webhooks)
ADMIN_API_KEY=change-me-to-a-random-key

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
